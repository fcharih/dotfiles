[git]
    autoCommit = true
    autoPush = true

[onepassword]
    mode = "account"

[data]
    environment = "{{ env "ENVIRONMENT" }}"

[hooks.read-source-state.pre]
script = "{{ .chezmoi.sourceDir }}/hooks/pre-source-read.sh"

[hooks.read-source-state.post]
script = "{{ .chezmoi.sourceDir }}/hooks/post-source-read.sh"

[hooks.apply.pre]
script = "{{ .chezmoi.sourceDir }}/hooks/pre-apply.sh"

[hooks.apply.post]
script = "{{ .chezmoi.sourceDir }}/hooks/post-apply.sh"

[hooks.add.pre]
script = "{{ .chezmoi.sourceDir }}/hooks/pre-add.sh"

[hooks.add.post]
script = "{{ .chezmoi.sourceDir }}/hooks/post-add.sh"